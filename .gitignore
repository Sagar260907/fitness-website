# ============================================
# .gitignore for FusionFit Fitness Website
# ============================================

# ----------------------------
# OS Generated Files
# ----------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~

# Windows
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp

# Linux
.directory
*.orig
*.old
*.bak

# ----------------------------
# IDE and Editor Files
# ----------------------------
# VS Code
.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# IntelliJ IDEA / WebStorm
.idea/
*.iml
*.ipr
*.iws
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.vim
*.vimrc
*.swp

# ----------------------------
# Video Files (Optional - Comment out if you want to include videos)
# ----------------------------
# Uncomment the lines below if you DON'T want to upload videos to GitHub
# videos are often large and may exceed GitHub file size limits
# *.mp4
# *.mov
# *.avi
# *.mkv
# *.webm
# *.flv
# *.wmv

# ----------------------------
# Image Files (Optional)
# ----------------------------
# Uncomment if you don't want to upload large images
# *.jpg
# *.jpeg
# *.png
# *.gif
# *.bmp
# *.tiff
# *.psd

# ----------------------------
# Logs and Databases
# ----------------------------
# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Database files (if using backend later)
*.db
*.sqlite
*.sqlite3

# ----------------------------
# Environment and Config Files
# ----------------------------
# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Config files with sensitive data
config.local.js
config.local.json
secrets.json

# ----------------------------
# Dependency Directories
# ----------------------------
# Node.js
node_modules/
package-lock.json
yarn.lock
npm-debug.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv

# ----------------------------
# Build and Distribution
# ----------------------------
# Build outputs
dist/
build/
out/
.next/
.nuxt/
.cache/

# Minified files
*.min.js
*.min.css

# ----------------------------
# Temporary Files
# ----------------------------
*.tmp
*.temp
*.cache
.cache/
.tmp/

# ----------------------------
# Backup Files
# ----------------------------
*.backup
*.bak
*.old
*.orig

# ----------------------------
# Project Specific
# ----------------------------
# Backup of your files
*.html.bak
*.css.bak
*.js.bak

# Test files (if you create tests later)
test/
tests/
coverage/
.nyc_output/

# ----------------------------
# Note: Keep videos if you want them on GitHub
# But GitHub has a 100MB file size limit per file
# For videos larger than 100MB, use Git LFS or store elsewhere
# ----------------------------